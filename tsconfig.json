{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "vitest/globals"],
    "outDir": "./dist",
    "rootDir": "./"
  },
  "include": [
    "index.ts",
    "src/**/*.ts",
    "tests/**/*.ts",
    "vite.config.ts",
    "vitest.integration.config.ts"
  ],
  "exclude": ["node_modules"]
}
